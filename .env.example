GOOGLE_API_KEY=your_google_api_key_here
CHUNK_SIZE=400
CHUNK_OVERLAP=50
TOP_K_RESULTS=5
MAX_FILE_SIZE_MB=200
# Use gemini-1.5-flash (stable, lower demand than 2.5-flash)
# Options: gemini-1.5-flash, gemini-1.5-flash-8b, gemini-1.5-pro, gemini-pro
GEMINI_MODEL=gemini-2.5-flash
# Use gemini-embedding-001 (embedding-001 / text-embedding-004 are retired on the Gemini API)
EMBEDDING_MODEL=gemini-embedding-001
# Optional: 128–3072 for gemini-embedding-001 (768 is a good RAG default)
EMBEDDING_OUTPUT_DIMENSIONALITY=768
REQUESTS_PER_MINUTE=15
